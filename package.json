{
  "name": "meetspace-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @meetspace/web run dev",
    "dev:api": "npm --workspace @meetspace/api run dev",
    "build:web": "npm --workspace @meetspace/web run build",
    "build:api": "npm --workspace @meetspace/api run build",
    "start:api": "npm --workspace @meetspace/api run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
